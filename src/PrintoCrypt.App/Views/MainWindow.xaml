<Window x:Class="PrintoCrypt.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrintoCrypt Settings"
        Height="520"
        Width="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="PrintoCrypt Settings"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"/>
            <TextBlock Text="Virtual printer that saves password-protected PDF files."
                       Margin="0,6,0,0"
                       Foreground="#64748B"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Output folder" FontWeight="SemiBold"/>
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputDirectoryBox" Height="36" Padding="8,6"/>
                    <Button Grid.Column="1"
                            Content="Browse"
                            Margin="8,0,0,0"
                            Width="90"
                            Height="36"
                            Click="BrowseOutputFolder_OnClick"/>
                </Grid>

                <TextBlock Text="Listen port" FontWeight="SemiBold"/>
                <TextBox x:Name="ListenPortBox"
                         Width="120"
                         HorizontalAlignment="Left"
                         Height="36"
                         Margin="0,8,0,16"
                         Padding="8,6"/>

                <TextBlock Text="Ghostscript path (optional)" FontWeight="SemiBold"/>
                <TextBlock Text="Leave empty to auto-detect. Required to convert PostScript to PDF."
                           Foreground="#64748B"
                           TextWrapping="Wrap"/>
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="GhostscriptPathBox" Height="36" Padding="8,6"/>
                    <Button Grid.Column="1"
                            Content="Browse"
                            Margin="8,0,0,0"
                            Width="90"
                            Height="36"
                            Click="BrowseGhostscript_OnClick"/>
                </Grid>

                <CheckBox x:Name="OpenOutlookCheckBox"
                          Content="Open Outlook with encrypted PDF attached"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="OpenFolderCheckBox"
                          Content="Open output folder after saving"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="StartupCheckBox"
                          Content="Start PrintoCrypt with Windows"
                          Margin="0,0,0,16"/>

                <Border BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="White">
                    <StackPanel>
                        <TextBlock Text="Printer setup"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"/>
                        <TextBlock Margin="0,8,0,12"
                                   TextWrapping="Wrap"
                                   Foreground="#475569"
                                   Text="Run the installer script as Administrator to register the PrintoCrypt virtual printer. The app must be running when you print."/>
                        <Button Content="Install printer (PowerShell)"
                                Height="36"
                                Click="InstallPrinter_OnClick"/>
                        <Button Content="Uninstall printer"
                                Height="36"
                                Margin="0,8,0,0"
                                Click="UninstallPrinter_OnClick"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Close"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="Close_OnClick"/>
            <Button Content="Save"
                    Width="100"
                    Height="36"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Save_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
