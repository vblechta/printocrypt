<Window x:Class="PrintoCrypt.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrintoCrypt Settings"
        Icon="/Assets/printocrypt.ico"
        Height="680"
        Width="560"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TitleText"
                       Text="PrintoCrypt Settings"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"/>
            <TextBlock x:Name="SubtitleText"
                       Text="Virtual printer that saves password-protected PDF files."
                       Margin="0,6,0,0"
                       Foreground="#64748B"/>
        </StackPanel>

        <TabControl x:Name="SettingsTabs"
                    Grid.Row="1"
                    SelectionChanged="SettingsTabs_OnSelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="16,10"/>
                    <Setter Property="Margin" Value="0,0,6,0"/>
                </Style>
            </TabControl.Resources>
            <TabItem x:Name="UserSettingsTabItem" Header="User settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                    <StackPanel>
                        <TextBlock x:Name="OutputFolderLabel" Text="Output folder" FontWeight="SemiBold"/>
                        <Grid Margin="0,8,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputDirectoryBox" Height="36" Padding="8,6"/>
                            <Button x:Name="BrowseButton"
                                    Grid.Column="1"
                                    Content="Browse"
                                    Margin="8,0,0,0"
                                    Width="90"
                                    Height="36"
                                    Click="BrowseOutputFolder_OnClick"/>
                        </Grid>

                        <CheckBox x:Name="OpenOutlookCheckBox"
                                  Content="Open Outlook with encrypted PDF attached"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="OpenFolderCheckBox"
                                  Content="Open output folder after saving"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="UseEmailTemplatesCheckBox"
                                  Content="Use email templates in password dialog"
                                  Margin="0,0,0,16"
                                  Checked="UseEmailTemplatesCheckBox_OnChanged"
                                  Unchecked="UseEmailTemplatesCheckBox_OnChanged"/>

                        <Border x:Name="EmailTemplatesPanel"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                Background="White"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="EmailTemplatesLabel"
                                           Text="Email templates"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"/>
                                <TextBlock x:Name="EmailTemplatesHelpText"
                                           Margin="0,8,0,12"
                                           TextWrapping="Wrap"
                                           Foreground="#475569"/>

                                <ListBox x:Name="TemplatesListBox"
                                         Height="90"
                                         DisplayMemberPath="Name"
                                         SelectionChanged="TemplatesListBox_OnSelectionChanged"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
                                    <Button x:Name="AddTemplateButton"
                                            Content="Add template"
                                            Height="32"
                                            MinWidth="100"
                                            Margin="0,0,8,0"
                                            Click="AddTemplate_OnClick"/>
                                    <Button x:Name="RemoveTemplateButton"
                                            Content="Remove"
                                            Height="32"
                                            MinWidth="80"
                                            Click="RemoveTemplate_OnClick"/>
                                </StackPanel>

                                <TextBlock x:Name="TemplateNameLabel" Text="Template name" FontWeight="SemiBold"/>
                                <TextBox x:Name="TemplateNameBox"
                                         Height="36"
                                         Margin="0,8,0,8"
                                         Padding="8,6"
                                         TextChanged="TemplateField_OnTextChanged"/>
                                <CheckBox x:Name="DefaultTemplateCheckBox"
                                          Content="Default template"
                                          Margin="0,0,0,12"
                                          Checked="DefaultTemplateCheckBox_OnChanged"
                                          Unchecked="DefaultTemplateCheckBox_OnChanged"/>

                                <TextBlock x:Name="TemplateSubjectLabel" Text="Subject" FontWeight="SemiBold"/>
                                <TextBox x:Name="TemplateSubjectBox"
                                         Height="36"
                                         Margin="0,8,0,12"
                                         Padding="8,6"
                                         TextChanged="TemplateField_OnTextChanged"/>

                                <TextBlock x:Name="TemplateBodyLabel" Text="Message" FontWeight="SemiBold"/>
                                <TextBox x:Name="TemplateBodyBox"
                                         MinHeight="72"
                                         Margin="0,8,0,0"
                                         Padding="8,6"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         TextChanged="TemplateField_OnTextChanged"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="GlobalSettingsTabItem" Header="Global settings">
                <Grid Margin="4,12,4,4">
                    <StackPanel x:Name="GlobalSettingsLockedPanel"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                MaxWidth="360">
                        <TextBlock x:Name="GlobalSettingsLockedTitle"
                                   Text="Administrator approval required"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Foreground="#0F172A"/>
                        <TextBlock x:Name="GlobalSettingsLockedText"
                                   Margin="0,12,0,16"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="#64748B"/>
                        <Button x:Name="UnlockGlobalSettingsButton"
                                Content="Continue as administrator"
                                Height="36"
                                HorizontalAlignment="Center"
                                MinWidth="220"
                                Click="UnlockGlobalSettings_OnClick"/>
                    </StackPanel>

                    <ScrollViewer x:Name="GlobalSettingsContent"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="GlobalSettingsDescriptionText"
                                       TextWrapping="Wrap"
                                       Foreground="#64748B"
                                       Margin="0,0,0,16"/>

                            <TextBlock x:Name="ListenPortLabel" Text="Listen port" FontWeight="SemiBold"/>
                            <TextBox x:Name="ListenPortBox"
                                     Width="120"
                                     HorizontalAlignment="Left"
                                     Height="36"
                                     Margin="0,8,0,16"
                                     Padding="8,6"/>

                            <CheckBox x:Name="StartupCheckBox"
                                      Content="Start PrintoCrypt with Windows"
                                      Margin="0,0,0,16"/>

                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock x:Name="PrinterSetupLabel"
                                               Text="Printer setup"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"/>
                                    <TextBlock x:Name="PrinterSetupDescriptionText"
                                               Margin="0,8,0,12"
                                               TextWrapping="Wrap"
                                               Foreground="#475569"/>
                                    <Button x:Name="InstallPrinterButton"
                                            Content="Install printer (PowerShell)"
                                            Height="36"
                                            Click="InstallPrinter_OnClick"/>
                                    <Button x:Name="UninstallPrinterButton"
                                            Content="Uninstall printer"
                                            Height="36"
                                            Margin="0,8,0,0"
                                            Click="UninstallPrinter_OnClick"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <TextBlock x:Name="VersionLink"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource AccentBrush}"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       MouseLeftButtonUp="VersionLink_OnClick"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CloseButton"
                        Content="Close"
                        Width="100"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="Close_OnClick"/>
                <Button x:Name="SaveButton"
                        Content="Save"
                        Width="100"
                        Height="36"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Save_OnClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
