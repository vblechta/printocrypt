<Window x:Class="PrintoCrypt.App.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrintoCrypt – Set PDF password"
        Icon="/Assets/printocrypt.ico"
        Width="460"
        SizeToContent="Height"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        Background="{StaticResource SurfaceBrush}">
    <DockPanel Margin="24">
        <Grid DockPanel.Dock="Bottom" Margin="0,20,0,0">
            <TextBlock x:Name="VersionText"
                       VerticalAlignment="Center"
                       Foreground="#94A3B8"
                       FontSize="12"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="100"
                        Height="36"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="CancelButton_OnClick"/>
                <Button x:Name="SubmitButton"
                        Content="Submit"
                        MinWidth="100"
                        Height="36"
                        Padding="16,0"
                        IsDefault="True"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SubmitButton_OnClick"/>
            </StackPanel>
        </Grid>

        <StackPanel>
            <StackPanel Margin="0,0,0,16">
                <TextBlock x:Name="HeaderText"
                           Text="Encrypt print job"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"/>
                <TextBlock x:Name="DocumentTitleText"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="#475569"/>
            </StackPanel>

            <StackPanel x:Name="TemplatePanel" Visibility="Collapsed">
                <TextBlock x:Name="TemplateLabel"
                           Text="Email template"
                           FontWeight="SemiBold"
                           Foreground="#334155"/>
                <ComboBox x:Name="TemplateComboBox"
                          Margin="0,8,0,0"
                          Height="36"
                          DisplayMemberPath="Name"/>
            </StackPanel>

            <TextBlock x:Name="PasswordLabel"
                       Text="Password"
                       Margin="0,16,0,0"
                       FontWeight="SemiBold"
                       Foreground="#334155"/>
            <PasswordBox x:Name="PasswordBox"
                         Margin="0,8,0,0"
                         Height="36"
                         Padding="8,6"
                         KeyDown="PasswordBox_OnKeyDown"/>

            <TextBlock x:Name="ConfirmPasswordLabel"
                       Text="Confirm password"
                       Margin="0,16,0,0"
                       FontWeight="SemiBold"
                       Foreground="#334155"/>
            <PasswordBox x:Name="ConfirmPasswordBox"
                         Margin="0,8,0,0"
                         Height="36"
                         Padding="8,6"
                         KeyDown="PasswordBox_OnKeyDown"/>

            <TextBlock x:Name="ErrorText"
                       Margin="0,12,0,0"
                       MinHeight="20"
                       Foreground="#DC2626"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </DockPanel>
</Window>
