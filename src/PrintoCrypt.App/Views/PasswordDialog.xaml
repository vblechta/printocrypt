<Window x:Class="PrintoCrypt.App.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrintoCrypt – Set PDF password"
        Height="320"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Encrypt print job"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"/>
            <TextBlock x:Name="DocumentTitleText"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="#475569"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="Password"
                   FontWeight="SemiBold"
                   Foreground="#334155"/>
        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="2"
                     Margin="0,8,0,0"
                     Height="36"
                     Padding="8,6"
                     KeyDown="PasswordBox_OnKeyDown"/>

        <TextBlock Grid.Row="3"
                   Text="Confirm password"
                   Margin="0,16,0,0"
                   FontWeight="SemiBold"
                   Foreground="#334155"/>
        <PasswordBox x:Name="ConfirmPasswordBox"
                     Grid.Row="4"
                     Margin="0,8,0,0"
                     Height="36"
                     Padding="8,6"
                     KeyDown="PasswordBox_OnKeyDown"/>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="5"
                   Margin="0,12,0,0"
                   Foreground="#DC2626"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="Save encrypted PDF"
                    Width="160"
                    Height="36"
                    IsDefault="True"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="SaveButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
